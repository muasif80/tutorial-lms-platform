# Copy to .env and adjust. docker-compose.yml reads these (with sane defaults if unset).
# In a real deployment these come from a secrets manager (Vault, AWS/GCP Secrets Manager), never a file in git.

DB_NAME=scholr
DB_USER=scholr
DB_PASSWORD=change-me-in-production

# Host port the app is published on (container always listens on 8080).
APP_PORT=8080

# JVM container tuning — let the JVM use a share of the container's memory limit.
JAVA_OPTS=-XX:MaxRAMPercentage=75
